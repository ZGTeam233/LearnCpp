# ==========================================
# 1. 编译中间产物与依赖
# ==========================================
# 编译生成的目标文件
*.slo
*.lo
*.o
*.obj

# 预编译头文件
*.gch
*.pch

# Fortran 模块文件
*.mod
*.smod

# Makefile 依赖文件 (如 gcc -MMD 生成的依赖)
*.d

# 日志文件
*.log
log/

# ==========================================
# 2. 链接与调试文件
# ==========================================
# 链接器生成的中间文件
*.ilk

# 调试信息与符号文件
*.pdb
*.dwo

# ==========================================
# 3. 库文件
# ==========================================
# 动态链接库
*.so
*.dylib
*.dll

# 静态链接库
*.lai
*.la
*.a
*.lib

# ==========================================
# 4. 可执行文件
# ==========================================
*.exe
*.out
*.app

# ==========================================
# 5. 构建输出目录
# ==========================================
# 构建输出目录
build/

# ==========================================
# 6. IDE 与编辑器配置
# ==========================================
# JetBrains 系列 IDE (如 CLion, IntelliJ IDEA 等) 配置目录
../cpp26test/.idea/